[user]
	name = Levi Wilkerson
	email = levi@leviwilkerson.com
[pull]
	rebase = true
[push]
	autoSetupRemote = true
[rerere]
	enabled = true
	autoupdate = true

[core]
	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	features = one-dark-pro
	line-numbers = true
	navigate = true
[merge]
	conflictStyle = zdiff3
[diff]
	colorMoved = default
[include]
	path = ~/.config/delta/themes.gitconfig

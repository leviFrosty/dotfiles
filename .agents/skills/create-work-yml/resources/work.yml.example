# Example smug config consumed by the `work` script.
# Save as ./work.yml at your project root.
#
# This example mirrors a pnpm + turborepo monorepo with a docker-compose
# postgres, a Next.js admin UI, a Cloudflare Worker API, a Shopify app, and
# a Shopify theme — adjust to your project's actual layout.

# tmux session name. Keep it short and unique per repo.
session: shopify

# Absolute path. The work script invokes `smug start -f ./work.yml`, so
# smug runs `cd <root>` before every pane.
root: /Users/levi/dev/shopify

# Run once before any windows/panes are created. Use this for:
#   - Preconditions (docker up, migrations, seeds) — must be idempotent and fast.
#   - Launching GUI apps you want open alongside the tmux session: editor,
#     browser tabs, design tool, chat app, API client, etc. Trail them with
#     `&` so they don't block pane startup.
#
# Pick the launch commands that match your OS / setup — there's no default.
# Examples below are commented out; uncomment/replace as needed.
on_project_start:
  - pnpm docker:up
  # --- editor (pick one or none) -----------------------------------------
  # - codium . &
  # - code . &
  # - cursor . &
  # - zed . &
  # - subl . &
  # - idea . &
  # macOS: open the project folder in your default editor
  # - open -a "Visual Studio Code" . &
  # --- browser tabs (macOS examples; adapt for your OS) ------------------
  # - open -a "Google Chrome" --args --new-window http://localhost:3000 &
  # - open -na "Google Chrome" --args --new-window http://localhost:8787/admin &
  # Linux:
  # - google-chrome --new-window http://localhost:3000 &
  # - firefox --new-window http://localhost:3000 &
  # --- other helpers -----------------------------------------------------
  # - open -a "TablePlus" mysql://localhost:3306 &
  # - open -a "Slack" &

windows:
  - name: dev
    layout: tiled
    # The first dev server uses the window's initial pane via window-level
    # `commands`. Subsequent panes go in the `panes` array. (Smug always
    # creates one starter pane per window — using `commands` here puts it
    # to work instead of leaving an empty shell.)
    commands:
      - cd apps/promo-admin
      - pnpm dev
    panes:
      - commands:
          - cd apps/promo-api
          - pnpm dev
      - commands:
          - cd apps/shopify-app
          - pnpm dev
      - commands:
          - cd apps/theme
          - pnpm dev

# Optional: stop hooks run when you `smug stop`.
# on_project_stop:
#   - pnpm docker:down
